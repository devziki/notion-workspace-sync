# =============================================================================
# Notion Workspace Sync Engine — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the real values.
# NEVER commit .env.local to git. Real tokens must only exist in:
#   - Your local .env.local (for development)
#   - Vercel Environment Variables (for production)
# =============================================================================

# -----------------------------------------------------------------------------
# Notion Integration Tokens
# Obtain from: https://www.notion.so/my-integrations
# Each token is the "Internal Integration Secret" for the respective workspace.
# -----------------------------------------------------------------------------
NOTION_ZIKI=
NOTION_NOTION_STATE=

# -----------------------------------------------------------------------------
# Notion Webhook Signing Secrets
# Obtain after registering a webhook in each Notion integration.
# Webhook registration URL for each integration → Capabilities → Webhooks.
# Main endpoint:  https://<your-vercel-url>/api/webhook/main
# Other endpoint: https://<your-vercel-url>/api/webhook/other
# -----------------------------------------------------------------------------
NOTION_WEBHOOK_SECRET_MAIN=
NOTION_WEBHOOK_SECRET_OTHER=

# -----------------------------------------------------------------------------
# Vercel KV (Redis)
# These are automatically set when you link a KV store in the Vercel dashboard.
# For local development: copy the values from Vercel → Storage → <your-kv> → .env.local
# -----------------------------------------------------------------------------
KV_REST_API_URL=
KV_REST_API_TOKEN=

# -----------------------------------------------------------------------------
# Dashboard access (HTTP Basic Auth)
# Protects the UI and all API endpoints except /api/webhook/*.
# Set to any username and a strong password of your choice.
# -----------------------------------------------------------------------------
DASHBOARD_USER=
DASHBOARD_PASSWORD=

# -----------------------------------------------------------------------------
# Feature 2 — Property name overrides (optional)
# These default to sensible values; only set if your workspace uses different
# property names. The Mapping UI (Feature 5) will surface these in the UI.
# -----------------------------------------------------------------------------
# SYNC_MAIN_TITLE_PROP=Name
# SYNC_MAIN_DUE_DATE_PROP=Due Date
# SYNC_MAIN_PROJECT_PROP=Project
# SYNC_MAIN_SPRINTS_PROP=Sprints
# SYNC_MAIN_DELEGATED_TO_PROP=Delegated To
# SYNC_OTHER_TITLE_PROP=Name
# SYNC_OTHER_DUE_DATE_PROP=Due Date
# SYNC_OTHER_PROJECT_PROP=Project
# SYNC_OTHER_SPRINTS_PROP=Sprints
# SYNC_OTHER_ASSIGNEE_PROP=Assignee
